# ===== LINE Messaging API =====
LINE_CHANNEL_SECRET=placeholder_line_channel_secret
LINE_ACCESS_TOKEN=placeholder_line_access_token

# ===== Supabase =====
SUPABASE_URL=https://placeholder.supabase.co
SUPABASE_SERVICE_ROLE_KEY=placeholder_service_role_key

# ===== Slip Verification Provider =====
# 'mock' for local/dev/test — never calls a real provider
SLIP_PROVIDER=mock

# ===== Cron =====
CRON_SECRET=placeholder_cron_secret

# ===== App base URL =====
# APP_BASE_URL: public base URL of the app, used to build the customer /plan/<token>
# calendar link (see lib/plan-token.ts). No trailing slash.
# Defaults to https://uplinebot-cyan.vercel.app when unset.
APP_BASE_URL=https://uplinebot-cyan.vercel.app

# ===== Test / Mock Mode Flags =====
# When 'true', lib/line/client.ts returns canned responses instead of calling the real LINE API
LINE_MOCK=true
# When 'true', the slip-verification module uses MockSlipProvider instead of a real provider
SLIP_MOCK=true

# ===== Encryption (optional in dev) =====
# ENCRYPTION_KEY: base64 of 32 random bytes for AES-256-GCM (used to encrypt *_enc columns).
# Generate with:  openssl rand -base64 32
# If unset, lib/crypto.ts falls back to a clearly-labeled reversible base64 stub (dev/test only).
# ENCRYPTION_KEY=placeholder_32_byte_base64_key

# ===== Admin API =====
# ADMIN_TOKEN: shared secret for the seller-only admin API (create tenant, grant modules,
# connect a LINE OA). Sent by the caller as the `x-admin-token` request header.
# The admin routes FAIL CLOSED — if this is unset, every admin request is rejected.
ADMIN_TOKEN=placeholder_admin_token
